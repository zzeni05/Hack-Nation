# LLM API keys (get at least one working)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Default LLM provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Supabase (optional — uncomment code in db.py to use)
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_KEY=eyJ...

# CORS — comma-separated origins. Add your Vercel URL on deploy.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# External retrieval (optional for MVP; used when Tavily adapter is enabled)
TAVILY_API_KEY=

# Local RAG / persistence
CHROMA_PATH=./data/chroma
KNOWLEDGE_PATH=./knowledge/internal
WORKFLOW_STORE_PATH=./data/workflows.json
FEEDBACK_STORE_PATH=./data/feedback.json
TRACE_STORE_PATH=./data/trace_events.json
PROTOCOL_CACHE_PATH=./data/protocol_candidates.json

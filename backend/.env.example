# LLM API keys (get at least one working)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Default LLM provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Supabase (optional — uncomment code in db.py to use)
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_KEY=eyJ...

# CORS — comma-separated origins. Add your Vercel URL on deploy.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
